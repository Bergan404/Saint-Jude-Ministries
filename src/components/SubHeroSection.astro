---
import type { ImageMetadata } from "astro";
import { getImage } from "astro:assets";

interface Props {
  imagePath: string | ImageMetadata;
  title: string;
  body: string;
}

const { imagePath, title, body } = Astro.props;

const imagePathAwaiting = await getImage({
  src: imagePath,
  format: "png",
  inferSize: true,
});

const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isAbout = pathname === "/about";
const isContact = pathname === "/contact";
---

<div class="nav-space"></div>

<header class={`hero ${isContact ? "contact-header" : ""}`} id="homecover-1">
  <picture>
    <img
      src={imagePathAwaiting.src}
      width={imagePathAwaiting.attributes.width}
      height={imagePathAwaiting.attributes.height}
      alt={title}
      id="houseopen"
    />
  </picture>

  <div class={isAbout ? "white-overlay" : isContact ? "overlay" : ""}></div>

  <div
    class="hero-content hero_text_shadow"
    data-aos="zoom-in"
    data-aos-easing="ease-out-back"
    data-aos-duration="2000"
    data-aos-delay="0"
  >
    <h1 class="bold mb-4">{title}</h1>
    <h2>{body}</h2>
  </div>
</header>

<style>
  .nav-space {
    height: 67px;
  }

  .hero {
    height: 340px;
    position: relative;
  }

  header {
    margin: auto;
    padding: 1rem;
    color: #434343;
    font-size: 20px;
    line-height: 1.6;
  }

  .contact-header {
    color: white;
  }

  #houseopen {
    position: absolute;
    right: 0;
    bottom: 0;
    min-width: 100%;
    min-height: 100%;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-content {
    display: grid;
    place-content: center;
    height: 100%;
    width: 100%;
    z-index: 10;
    position: relative;
    text-align: center;
  }

  .overlay,
  .white-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .overlay {
    background-color: rgba(0, 0, 0, 0.5);
  }

  .white-overlay {
    background-color: rgba(255, 255, 255, 0.4);
  }
</style>
