---
export const prerender = false;

const response = await fetch(
  "https://cms.oudsdev.com/api/content/saint-jude/saint-jude-ministies/cta-button",
);
const data = await response.json();
const ctaButton = data.sectionsMap;
---

<div class="py-4 book_next_event col col-md-6 m-auto text-center">
  <p>{ctaButton.book_next_event.content.text}</p>
  <a href="/contact"
    ><button>{ctaButton.book_next_event.content.button_text}</button></a
  >
</div>

<style lang="scss">
  .book_next_event {
    p {
      font-style: italic;
      color: #666666;
      font-size: 21px;
      font-family: "Gentium Basic", serif;

      @media (max-width: 992px) {
        // font-size: 17px;
      }
    }

    button {
      border: none;
      text-transform: uppercase;
      background-color: #1e6c93;
      width: 100%;
      color: white;
      padding: 6px;
      border-radius: 5px;
      font-family: "Gentium Basic", serif;
    }
  }
</style>
